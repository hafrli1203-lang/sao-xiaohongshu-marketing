# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# omc state
.omc/

# vercel
.vercel

# 내부 자료 (public repo에 노출 금지)
*.pdf
*.pptx
*.docx
*.xlsx
*.psd
*.hwp
페이퍼로지 폰트/

# 폰트 파일 (라이선스 문제 방지)
public/fonts/*.ttf
public/fonts/*.otf
public/fonts/*.woff
public/fonts/*.woff2

# API 키 / 시크릿
.env
.env.*
!.env.local.example
*.key
*.secret

# claude config
.claude/

# 루트의 제안서/상품안내 이미지 (public/images 제외)
/샤오홍슈*.jpg
/KakaoTalk*.jpg

# typescript
*.tsbuildinfo
next-env.d.ts
